<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="720.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="me.panjohnny.trenovacmaturity.fx.MaturitaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <HBox prefHeight="100.0" prefWidth="200.0">
      <children>
         <Label fx:id="infoLabel" />
      </children>
   </HBox>
   <Canvas fx:id="canvas" height="400.0" width="500.0" />
   <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Button fx:id="prev" mnemonicParsing="false" onAction="#onPrevClick" text="Prev" />
         <Button fx:id="next" alignment="CENTER_RIGHT" mnemonicParsing="false" onAction="#onNextClick" text="Next" />
         <Separator orientation="VERTICAL" prefHeight="200.0" />
         <TextField promptText="Tags separated by ," />
         <Separator orientation="VERTICAL" prefHeight="200.0" />
         <Button mnemonicParsing="false" text="Show correct answer" />
      </children>
   </HBox>
   <ScrollPane prefHeight="200.0" prefWidth="200.0">
     <content>
       <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0">
            <children>
            
                <Label fx:id="welcomeText" />
            </children>
         </AnchorPane>
     </content>
   </ScrollPane>
</VBox>
