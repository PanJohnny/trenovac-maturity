<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="me.panjohnny.trenovacmaturity.fx.training.TrainingSelectExamController">
    <Label alignment="TOP_CENTER" contentDisplay="CENTER" text="Nový trénink" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
        <font>
            <Font size="24.0" />
        </font>
    </Label>

    <Label alignment="TOP_CENTER" contentDisplay="CENTER" minHeight="-Infinity" text="Trénink je sada úloh, které chcete procvičovat. Nejdříve vyberete všechny soubory testů, ze kterých chcete čerpat (.MATURITA). Následně můžete vyfiltrovat odpovědi podle štítků, či manuálně vyklikáním. Trénink se uloží jako soubor s koncovkou .TRAIN.MATURITA. Tento soubor následně můžete libovolně znovu otevírat. Lze otevřít i v režimu paniky, kdy máte na každou otázku velmi krátký čas." wrapText="true" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
        <font>
            <Font size="14.0" />
        </font>
    </Label>

    <Label alignment="TOP_CENTER" contentDisplay="CENTER" text="Vyberte maturity" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
        <font>
            <Font size="20.0" />
        </font>
    </Label>
   <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
      <VBox spacing="10.0">
          <FlowPane prefHeight="200.0" prefWidth="200.0" fx:id="selectedExams" hgap="10" vgap="10" VBox.vgrow="ALWAYS">
              <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
              </padding>
              <Button maxWidth="400" mnemonicParsing="false" onAction="#addFile" prefHeight="200.0" prefWidth="200.0" styleClass="linkpane" text="+ Přidat soubor(y)" />
          </FlowPane>
          <HBox alignment="CENTER" maxHeight="100.0" prefHeight="100.0" prefWidth="200.0" spacing="10" VBox.vgrow="ALWAYS">
              <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
              </padding>
              <Button mnemonicParsing="false" onAction="#closeExam" prefWidth="200.0" text="Domů" style="-fx-background-color: blue" HBox.hgrow="ALWAYS" />
              <Button mnemonicParsing="false" onAction="#createTraining" prefWidth="200.0" text="Resetovat" style="-fx-background-color: red" HBox.hgrow="ALWAYS" />
              <Button mnemonicParsing="false" onAction="#nextStep" prefWidth="200.0" text="Další krok" style="-fx-background-color: green" HBox.hgrow="ALWAYS" />
          </HBox>
      </VBox>
   </ScrollPane>
</VBox>
