<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<VBox stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="me.panjohnny.trenovacmaturity.fx.training.TrainingCreateController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <Label alignment="TOP_CENTER" contentDisplay="CENTER" text="Testy naimportovány" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0"/>
        </padding>
        <font>
            <Font size="24.0"/>
        </font>
    </Label>

    <Label alignment="TOP_CENTER" contentDisplay="CENTER" minHeight="-Infinity"
           text="Chcete vyfiltrovat otázky podle štítku? Vyberte možnost. Jinak zadejte název testu." wrapText="true"
           VBox.vgrow="ALWAYS">
        <font>
            <Font size="14.0"/>
        </font>
    </Label>

    <TextField fx:id="trainingName" text="Název tréninku"/>

    <CheckBox fx:id="filterEnable">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </padding>
        Filtrovat podle štítků
    </CheckBox>

    <VBox fx:id="filtersContainer">
        <VBox.margin>
            <Insets left="20.0" right="20.0"/>
        </VBox.margin>
        <Label alignment="TOP_CENTER" contentDisplay="CENTER" text="Zaklikejte možnosti, které chcete vyfiltrovat"
               VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <font>
                <Font size="20.0"/>
            </font>
        </Label>
    </VBox>

    <HBox alignment="CENTER" maxHeight="100.0" prefHeight="100.0" prefWidth="200.0" spacing="10" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </padding>
        <Button mnemonicParsing="false" onAction="#closeExam" prefWidth="200.0" text="Domů"
                style="-fx-background-color: blue" HBox.hgrow="ALWAYS"/>
        <Button mnemonicParsing="false" onAction="#createAndExportTraining" prefWidth="200.0" text="Vytvořit sadu"
                style="-fx-background-color: green" HBox.hgrow="ALWAYS"/>
    </HBox>
</VBox>
