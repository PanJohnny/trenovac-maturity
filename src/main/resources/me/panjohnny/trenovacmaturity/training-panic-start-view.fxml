<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<VBox stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="me.panjohnny.trenovacmaturity.fx.TrainingPanicStartController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <Label alignment="TOP_CENTER" contentDisplay="CENTER" text="Režim paniky" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0"/>
        </padding>
        <font>
            <Font size="24.0"/>
        </font>
    </Label>

    <Label alignment="TOP_CENTER" contentDisplay="CENTER" minHeight="-Infinity"
           text="Při režimu paniky vyberte všechny MATURITA testové soubory, ze kterých chcete čerpat data. Z nich budou vybírány náhodné testové otázky, na něž budete mít velmi málo času." wrapText="true"
           VBox.vgrow="ALWAYS">
        <font>
            <Font size="14.0"/>
        </font>
    </Label>

    <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0">
            <FlowPane prefHeight="200.0" prefWidth="200.0" fx:id="selectedExams" hgap="10" vgap="10" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                <Button maxWidth="400" mnemonicParsing="false" onAction="#addFile" prefHeight="200.0" prefWidth="200.0" styleClass="linkpane" text="+ Přidat soubor(y)" />
            </FlowPane>
            <HBox alignment="CENTER" maxHeight="100.0" prefHeight="100.0" prefWidth="200.0" spacing="10" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                <Button mnemonicParsing="false" onAction="#closeExam" prefWidth="200.0" text="Domů" style="-fx-background-color: blue" HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#startPanicMode" prefWidth="200.0" text="Resetovat" style="-fx-background-color: red" HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#nextStep" prefWidth="200.0" text="Další krok" style="-fx-background-color: green" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
